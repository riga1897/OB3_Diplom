# ============================================
# OB3 Document Processing Service
# Local Development Configuration
# ============================================
# Для: Replit, Windows, Linux, macOS
# Без: nginx, Redis, Celery worker
#
# Использование:
#   cp .env.develop.example .env.develop

# ============================================
# Окружение
# ============================================
ENVIRONMENT=development
DJANGO_SETTINGS_MODULE=config.settings.development

# ============================================
# Основные настройки Django
# ============================================
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ============================================
# База данных (PostgreSQL) — ОБЯЗАТЕЛЬНО!
# ============================================
# Вариант 1: DATABASE_URL (Replit создаёт автоматически)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# Вариант 2: Отдельные параметры (все 5 обязательны!)
DB_NAME=ob3_documents
DB_USER=ob3_user
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# ============================================
# Celery (синхронный режим без Redis)
# ============================================
CELERY_TASK_ALWAYS_EAGER=True

# ============================================
# Кэширование (локальный кэш в памяти)
# ============================================
CACHE_BACKEND=locmem
CACHE_TIMEOUT=300

# ============================================
# CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# Часовой пояс
# ============================================
TZ=Europe/Moscow

# ============================================
# Логирование
# ============================================
LOG_LEVEL=DEBUG

# ============================================
# DRF
# ============================================
DRF_PAGE_SIZE=20

# ============================================
# Throttling
# ============================================
THROTTLE_ANON=100/day
THROTTLE_USER=1000/day
THROTTLE_UPLOAD=10/hour

# ============================================
# Загрузка файлов
# ============================================
MAX_UPLOAD_SIZE=10485760

# ============================================
# Почта (консоль)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
