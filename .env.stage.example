# ============================================
# OB3 Document Processing Service
# Docker/Staging Environment Configuration
# ============================================
# Для: Docker Compose с nginx, Redis, Celery
#
# Использование:
#   cp .env.example .env

# ============================================
# Окружение
# ============================================
ENVIRONMENT=staging
DJANGO_SETTINGS_MODULE=config.settings.staging

# ============================================
# Django
# ============================================
SECRET_KEY=replace-with-secure-random-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# База данных PostgreSQL — ОБЯЗАТЕЛЬНО!
# ============================================
# Все 5 параметров обязательны — приложение не запустится без них
DB_NAME=ob3_documents
DB_USER=ob3_user
DB_PASSWORD=replace_with_secure_password
DB_HOST=postgres
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ============================================
# Redis и Celery
# ============================================
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# ============================================
# Кэширование
# ============================================
CACHE_BACKEND=redis
CACHE_TIMEOUT=60

# ============================================
# CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:80
CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# Часовой пояс
# ============================================
TZ=Europe/Moscow

# ============================================
# Логирование
# ============================================
LOG_LEVEL=INFO

# ============================================
# DRF
# ============================================
DRF_PAGE_SIZE=20

# ============================================
# Throttling
# ============================================
THROTTLE_ANON=100/day
THROTTLE_USER=1000/day
THROTTLE_UPLOAD=10/hour

# ============================================
# Загрузка файлов
# ============================================
MAX_UPLOAD_SIZE=10485760

# ============================================
# Безопасность
# ============================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ============================================
# Почта
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
